// Prisma Schema — Перечинська ЦРЛ
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  DOCTOR
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  DONE
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String
  phone           String?
  role            Role      @default(USER)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")

  // Fields for doctors (if role is DOCTOR)
  specialtyId     String?   @map("specialty_id")
  photoUrl        String?   @map("photo_url")
  bioUA           String?   @db.Text @map("bio_ua")
  bioEN           String?   @db.Text @map("bio_en")

  specialty       Specialty? @relation(fields: [specialtyId], references: [id])
  requests        Request[]  @relation("UserRequests")
  appointments    Request[]  @relation("DoctorRequests")
  logs            Log[]

  @@map("users")
}

model Request {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  doctorId        String?       @map("doctor_id")
  title           String
  description     String        @db.Text
  status          RequestStatus @default(NEW)
  category        String?       @default("MEDICAL")
  appointmentDate DateTime?     @map("appointment_date")
  appointmentTime String?       @map("appointment_time")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt       @map("updated_at")

  user            User          @relation("UserRequests", fields: [userId], references: [id], onDelete: Cascade)
  doctor          User?         @relation("DoctorRequests", fields: [doctorId], references: [id], onDelete: SetNull)

  @@map("requests")
}

model Specialty {
  id      String   @id @default(cuid())
  nameUA  String   @map("name_ua")
  nameEN  String   @map("name_en")
  doctors User[]

  @@map("specialties")
}

// Doctor model removed as fields merged into User

model Log {
  id        String   @id @default(cuid())
  action    String
  userId    String?  @map("user_id")
  timestamp DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("logs")
}
